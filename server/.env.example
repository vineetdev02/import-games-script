# Copy to .env and fill in. NEVER commit .env.
# Use the ANON key here, NOT service_role.
# If you need write access, set up RLS rules on the `games` table so the
# anon key can insert when an authenticated admin user is making the call.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Server port (default 5174 to avoid Next.js dev on 3000 and Vite on 5173)
PORT=5174

# How aggressive to be on imports
IMPORT_BATCH_SIZE=100
IMPORT_CONCURRENCY=5

# Cache-bust the web app after each successful batch. Both must be
# set or revalidation is silently skipped (importer still runs).
# REVALIDATE_URL=https://actiongames.io/api/revalidate
# REVALIDATE_SECRET=match-this-with-web0.2-env-local
